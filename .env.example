# TorqueTrace — backend
DATABASE_URL=postgresql://torquetrace:torquetrace@localhost:5432/torquetrace

# OpenAI — disabled by default (no API calls, no key used). Set to true only when you want ChatGPT + optional web research.
TORQUE_USE_OPENAI=false

OPENAI_API_KEY=

# Final JSON synthesis model (recommended: gpt-4o for better reasoning)
OPENAI_MODEL=gpt-4o

# Comma-separated list tried in order for the web-research pass (Responses API + web_search tool).
# Requires a model your account can call with web search (see OpenAI docs). Examples: gpt-4.1, gpt-4o
OPENAI_RESEARCH_MODEL=gpt-4.1,gpt-4o,gpt-4o-mini

# Set to false to skip live web search and use an expert internal research memo only
TORQUE_WEB_SEARCH=true

# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
